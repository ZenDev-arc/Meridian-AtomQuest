generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPLOYEE
  MANAGER
  ADMIN
}

enum CyclePhase {
  GOAL_SETTING
  Q1
  Q2
  Q3
  Q4
}

enum UomType {
  MIN
  MAX
  TIMELINE
  ZERO
}

enum GoalStatus {
  DRAFT
  SUBMITTED
  APPROVED
  RETURNED
}

enum ProgressStatus {
  NOT_STARTED
  ON_TRACK
  COMPLETED
}

enum ApprovalAction {
  APPROVED
  RETURNED
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  passwordHash  String
  role          Role      @default(EMPLOYEE)
  managerId     String?
  manager       User?     @relation("ManagerToEmployee", fields: [managerId], references: [id])
  employees     User[]    @relation("ManagerToEmployee")
  department    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  goals         Goal[]    @relation("UserGoals")
  approvals     Approval[] @relation("ManagerApprovals")
  goalSheetApprovals Approval[] @relation("EmployeeGoalSheet")
  auditLogs     AuditLog[] @relation("AuditChangedBy")
}

model Cycle {
  id            String    @id @default(uuid())
  name          String    // e.g. "FY 2025-26"
  phase         CyclePhase @default(GOAL_SETTING)
  windowOpen    DateTime
  windowClose   DateTime
  isActive      Boolean   @default(false)
  
  goals         Goal[]
}

model Goal {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation("UserGoals", fields: [userId], references: [id])
  cycleId       String
  cycle         Cycle     @relation(fields: [cycleId], references: [id])
  thrustArea    String
  title         String
  description   String?
  uomType       UomType
  targetValue   Float?    // For MIN, MAX, ZERO
  targetDate    DateTime? // For TIMELINE
  weightage     Float
  status        GoalStatus @default(DRAFT)
  isShared      Boolean   @default(false)
  parentGoalId  String?
  parentGoal    Goal?     @relation("SharedGoals", fields: [parentGoalId], references: [id])
  sharedCopies  Goal[]    @relation("SharedGoals")
  lockedAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  checkIns      CheckIn[]
}

model CheckIn {
  id              String    @id @default(uuid())
  goalId          String
  goal            Goal      @relation(fields: [goalId], references: [id])
  cyclePhase      CyclePhase
  actualValue     Float?
  actualDate      DateTime?
  progressStatus  ProgressStatus @default(NOT_STARTED)
  computedScore   Float?
  managerComment  String?
  checkedInAt     DateTime  @default(now())
}

model Approval {
  id                String    @id @default(uuid())
  goalSheetUserId   String
  goalSheetUser     User      @relation("EmployeeGoalSheet", fields: [goalSheetUserId], references: [id])
  managerId         String
  manager           User      @relation("ManagerApprovals", fields: [managerId], references: [id])
  action            ApprovalAction
  comment           String?
  actionedAt        DateTime  @default(now())
  cycleId           String?
}

model AuditLog {
  id            String    @id @default(uuid())
  entityType    String    // e.g., "Goal", "Target"
  entityId      String
  changedById   String
  changedBy     User      @relation("AuditChangedBy", fields: [changedById], references: [id])
  fieldName     String
  oldValue      String?
  newValue      String?
  changedAt     DateTime  @default(now())
}

model RevokedToken {
  id            String    @id @default(uuid())
  jti           String    @unique
  revokedAt     DateTime  @default(now())
  expiresAt     DateTime
}
